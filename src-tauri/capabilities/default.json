{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the Re:OS desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:path:default",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    "shell:allow-open",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://export.arxiv.org/*" },
        { "url": "https://arxiv.org/*" }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "sql:allow-load",
    "sql:allow-select",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-open-url",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": true
        },
        {
          "name": "open",
          "cmd": "open",
          "args": true
        }
      ]
    }
  ]
}
